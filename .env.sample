# === バージョン指定 ===
WP_VERSION=6.7
PHP_VERSION=8.3

# === ポート ===
WP_PORT=8888
PMA_PORT=8080

# === サブディレクトリ構成 ===
# WP_BASE: HOME（公開ルート）を置くサブディレクトリ。
#   空      … HOME=/（ルート直下。ルートには静的ファイル等を別途配置できる）
#   blog 等 … HOME=/blog, SITE=/blog/${WP_SUBDIR}
WP_BASE=

# WPコアを HOME 直下の /app に閉じ込める（空文字なら HOME 直下のまま）
WP_SUBDIR=app

# === ホスト側のdistディレクトリ ===
# WP_SUBDIRとは独立して設定できる（サブディレクトリなしでも空にならない）
DIST_PATH=dist/app
